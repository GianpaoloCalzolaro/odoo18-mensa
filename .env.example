# Identificativo univoco del progetto (router Traefik, volumi, nomi container)
PROJECT_NAME=nomecliente
COMPOSE_PROJECT_NAME=nomecliente

# Dominio pubblico dell'istanza
DOMAIN=odoo.nomecliente.it

# Immagine Docker specifica di questo progetto
ODOO_IMAGE=ghcr.io/[username]/odoo18-nomecliente:latest

# Credenziali database
POSTGRES_DB=odoo
POSTGRES_USER=odoo
POSTGRES_PASSWORD=CAMBIA_QUESTA_PASSWORD

# Password amministratore Odoo
ODOO_ADMIN_PASSWD=CAMBIA_QUESTA_PASSWORD

# Versioni
ODOO_VERSION=18.0
POSTGRES_VERSION=16
